{
  "title": "Approved Pen Test Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalog_version", "critical_minimum", "tests"],
  "properties": {
    "catalog_version": { "type": "string", "minLength": 1 },
    "critical_minimum": { "type": "integer", "minimum": 1 },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "domain",
          "target",
          "entry_point",
          "critical",
          "safety_class"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "entry_point": { "type": "string", "minLength": 1 },
          "critical": { "type": "boolean" },
          "safety_class": { "enum": ["S0", "S1", "S2", "S3"] }
        }
      }
    }
  }
}
