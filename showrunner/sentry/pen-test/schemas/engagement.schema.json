{
  "title": "Pen Test Engagement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "engagement_id",
    "authorization",
    "scope",
    "catalog",
    "window",
    "safety",
    "data_handling",
    "emergency",
    "cleanup"
  ],
  "properties": {
    "engagement_id": { "type": "string", "minLength": 1 },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved",
        "owner",
        "approved_at",
        "evidence",
        "rules_path",
        "roe_hash"
      ],
      "properties": {
        "approved": { "const": true },
        "owner": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "format": "date-time" },
        "evidence": { "type": "string", "minLength": 1 },
        "rules_path": { "type": "string", "minLength": 1 },
        "roe_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targets",
        "exclusions",
        "third_party_boundaries",
        "manifest_path",
        "scope_hash"
      ],
      "properties": {
        "targets": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "exclusions": { "type": "array", "items": { "type": "string" } },
        "third_party_boundaries": { "type": "array", "items": { "type": "string" } },
        "manifest_path": { "type": "string", "minLength": 1 },
        "scope_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved", "reviewer", "path", "digest"],
      "properties": {
        "approved": { "const": true },
        "reviewer": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["starts_at", "ends_at", "timezone"],
      "properties": {
        "starts_at": { "type": "string", "format": "date-time" },
        "ends_at": { "type": "string", "format": "date-time" },
        "timezone": { "type": "string", "minLength": 1 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximum_class",
        "rate_limit",
        "prohibited_actions",
        "s3_authorizations"
      ],
      "properties": {
        "maximum_class": { "enum": ["S0", "S1", "S2", "S3"] },
        "rate_limit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_requests_per_second",
            "max_concurrency",
            "max_payload_bytes"
          ],
          "properties": {
            "max_requests_per_second": { "type": "integer", "minimum": 1 },
            "max_concurrency": { "type": "integer", "minimum": 1 },
            "max_payload_bytes": { "type": "integer", "minimum": 1 }
          }
        },
        "prohibited_actions": {
          "type": "array",
          "minItems": 11,
          "uniqueItems": true,
          "items": {
            "enum": [
              "denial-of-service",
              "persistence",
              "lateral-movement",
              "real-data-exfiltration",
              "destructive-production-actions",
              "social-engineering",
              "physical-access",
              "wireless-attacks",
              "credential-stuffing",
              "broad-password-attacks",
              "concealment"
            ]
          }
        },
        "s3_authorizations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "test_id",
              "approved_by",
              "approval_evidence",
              "observer",
              "recovery_plan",
              "stop_path"
            ],
            "properties": {
              "test_id": { "type": "string", "minLength": 1 },
              "approved_by": { "type": "string", "minLength": 1 },
              "approval_evidence": { "type": "string", "minLength": 1 },
              "observer": { "type": "string", "minLength": 1 },
              "recovery_plan": { "type": "string", "minLength": 1 },
              "stop_path": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "data_handling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "storage",
        "retention",
        "redaction",
        "evidence_freshness_days"
      ],
      "properties": {
        "classification": { "type": "string", "minLength": 1 },
        "storage": { "type": "string", "minLength": 1 },
        "retention": { "type": "string", "minLength": 1 },
        "redaction": { "type": "string", "minLength": 1 },
        "evidence_freshness_days": { "type": "integer", "minimum": 1 }
      }
    },
    "emergency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contact",
        "stop_conditions",
        "kill_switch",
        "service_health_observer"
      ],
      "properties": {
        "contact": { "type": "string", "minLength": 1 },
        "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "kill_switch": { "type": "string", "minLength": 1 },
        "service_health_observer": { "type": "string", "minLength": 1 }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "deadline", "artifacts"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "deadline": { "type": "string", "format": "date-time" },
        "artifacts": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
