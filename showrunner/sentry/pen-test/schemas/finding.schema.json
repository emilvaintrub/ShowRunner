{
  "title": "Validated Pen Test Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "engagement_id",
    "scope_hash",
    "roe_hash",
    "title",
    "target",
    "claim",
    "root_cause",
    "preconditions",
    "impact",
    "evidence",
    "counter_evidence",
    "confidence",
    "discovered_by",
    "validator",
    "poc_verified",
    "cleanup",
    "retest_required"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "engagement_id": { "type": "string", "minLength": 1 },
    "scope_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "roe_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "title": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "claim": { "type": "string", "minLength": 1 },
    "root_cause": { "type": "string", "minLength": 1 },
    "preconditions": { "type": "array", "items": { "type": "string" } },
    "impact": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "counter_evidence": { "type": "array", "items": { "type": "string" } },
    "standards": { "type": "array", "items": { "type": "string" } },
    "confidence": { "enum": ["confirmed", "likely", "needs-review", "rejected"] },
    "discovered_by": { "type": "string", "minLength": 1 },
    "validator": { "type": "string", "minLength": 1 },
    "poc_verified": { "type": "boolean" },
    "cleanup": { "type": "string", "minLength": 1 },
    "retest_required": { "type": "boolean" }
  }
}
